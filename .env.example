# Telegram bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_TELEGRAM_IDS=123456789

# Database + cache
# On Railway, DATABASE_URL and REDIS_URL are created automatically by the PostgreSQL and Redis plugins.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/alphapulse?schema=public
REDIS_URL=redis://redis:6379

# App environment
NODE_ENV=production
PORT=3000

# Bot and app URLs
WEB_APP_URL=https://yourdomain.com/webapp
WEBHOOK_URL=https://yourdomain.com/telegram/<your-webhook-secret>
WEBHOOK_SECRET=your_webhook_secret
BOT_MODE=polling

# Payment wallets
SOL_PAYMENT_WALLET=your_solana_wallet_for_sol
SOL_USDT_PAYMENT_WALLET=your_solana_wallet_for_spl_usdt
TON_PAYMENT_WALLET=your_ton_wallet

# Optional API keys
HELIUS_API_KEY=your_helius_api_key
BIRDEYE_API_KEY=your_birdeye_api_key
TONCENTER_API_KEY=your_toncenter_api_key
AI_PROVIDER_URL=https://api.your-ai-provider.com
AI_API_KEY=your_ai_api_key

# HTTPS deployment helpers for Caddy
DOMAIN=yourdomain.com
TLS_EMAIL=you@example.com
