{
  "name": "alphapulse-bot",
  "version": "1.0.0",
  "description": "Solana Wallet Tracking and Intelligence Bot",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "predeploy": "npm run prisma:deploy",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:deploy": "npx prisma migrate deploy",
    "docker:up": "docker-compose up -d"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pino": "^8.16.2",
    "pino-pretty": "^13.1.3",
    "telegraf": "^4.15.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20.10.0",
    "prisma": "^7.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "bullmq": "^5.7.0"
  }
}
